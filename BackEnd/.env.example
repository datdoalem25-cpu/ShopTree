# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# CORS frontend origin (Vercel frontend URL)
FRONTEND_ORIGIN=https://your-frontend-project.vercel.app

# Optional fallback URL encoded into QR track links
PUBLIC_TRACK_BASE_URL=https://your-frontend-project.vercel.app

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Optional
PORT=5000
